# Use networkx for offline submission, or neo4j after starting Neo4j Desktop.
GRAPH_BACKEND=networkx

# Neo4j Desktop connection. Only needed when GRAPH_BACKEND=neo4j.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_desktop_password

# GraphRAG retrieval settings.
MAX_HOPS=2
EMBEDDING_DIM=64

# Flat RAG baseline settings.
FLAT_RAG_TOP_K=3

# Optional OpenAI settings. Leave OPENAI_API_KEY empty for the offline pipeline.
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small

# Used only for estimated benchmark cost in the report.
INPUT_COST_PER_1K_TOKENS=0.00015
OUTPUT_COST_PER_1K_TOKENS=0.00060
